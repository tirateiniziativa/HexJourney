# URL del Worker Cloudflare per il realtime (WebSocket).
# In sviluppo locale (wrangler dev): ws://localhost:8787
# In produzione (Cloudflare Pages): wss://<worker-domain>
VITE_WORKER_WS_URL=ws://localhost:8787

# Opzionale: base HTTP del Worker per POST /session. Se omessa, viene derivata da
# VITE_WORKER_WS_URL (ws->http, wss->https).
# VITE_WORKER_BASE_URL=http://localhost:8787
